#!/bin/bash

CACHE_FILE="/tmp/orthocal_cache.json"
COLOR="34"
BLUE="\e[${COLOR}m"
RESET="\e[0m"

SYS_YEAR=$(date +%Y)
SYS_MONTH=$(date +%m)
SYS_DAY=$(date +%d)
SYS_DATE_FULL=$(date +%Y-%m-%d)

SHOULD_DOWNLOAD=false

if [[ ! -f "$CACHE_FILE" ]]; then
    SHOULD_DOWNLOAD=true
else
    CACHE_DATE=$(jq -r '.date // empty' "$CACHE_FILE" 2>/dev/null)
    if [[ "$CACHE_DATE" != "$SYS_DATE_FULL" ]]; then
        SHOULD_DOWNLOAD=true
    fi
fi

if [[ "$SHOULD_DOWNLOAD" == "true" ]]; then
    curl -s --max-time 5 "https://orthocal.info/api/gregorian/$SYS_YEAR/$SYS_MONTH/$SYS_DAY/" > "${CACHE_FILE}.tmp" && mv "${CACHE_FILE}.tmp" "$CACHE_FILE"
fi

DATA=$(cat "$CACHE_FILE" 2>/dev/null)

if [[ -z "$DATA" ]] || [[ "$DATA" == "null" ]]; then
    echo -e "${BLUE}茶닎 Error: Data unavailable.${RESET}"
    exit 1
fi

DATE_STR=$(date "+%A %d, %B %Y")
TITLE=$(echo "$DATA" | jq -r '.summary_title // "No Title"')
LEVEL=$(echo "$DATA" | jq -r '.feast_level_description // ""')
READINGS=$(echo "$DATA" | jq -r '.readings | map(.display) | join("; ") // "No Readings"')
FAST_DESC=$(echo "$DATA" | jq -r '.fast_level_desc // "No Fasting Info"')
FAST_EXC=$(echo "$DATA" | jq -r '.fast_exception_desc // ""')

TITLE_LINE="$TITLE"
[[ -n "$LEVEL" ]] && [[ "$LEVEL" != "null" ]] && TITLE_LINE="$TITLE ($LEVEL)"

FAST_LINE="$FAST_DESC"
if [[ -n "$FAST_EXC" ]] && [[ "$FAST_EXC" != "No exception" ]] && [[ "$FAST_EXC" != "null" ]]; then
    FAST_LINE="$FAST_DESC ($FAST_EXC)"
fi

mapfile -t SAINTS < <(echo "$DATA" | jq -r '.saints[0:5][]')

LEFT_COL=(
    "箚툠 $DATE_STR"
    "茶닎 $TITLE_LINE"
    "茶뿓 $FAST_LINE"
    "箚뿂 $READINGS"
)

MAX_LINES=${#LEFT_COL[@]}
[[ ${#SAINTS[@]} -gt $MAX_LINES ]] && MAX_LINES=${#SAINTS[@]}

COL_WIDTH=45

for ((i=0; i<MAX_LINES; i++)); do
    LEFT="${LEFT_COL[$i]:-}"
    RIGHT="${SAINTS[$i]:-}"
    [[ -n "$RIGHT" ]] && RIGHT="箚슊 $RIGHT"
    printf "${BLUE}%-${COL_WIDTH}b %b${RESET}\n" "$LEFT" "$RIGHT"
done
